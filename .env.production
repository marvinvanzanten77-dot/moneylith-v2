# Plaid Configuration (Production Ready)
# ============================================================
# This file documents what needs to be set when production
# credentials arrive from Plaid. DO NOT PUT PRODUCTION KEYS HERE!
#
# All production keys go ONLY in Vercel Dashboard:
# https://vercel.com/dashboard → Settings → Environment Variables
#
# Current Status: WAITING FOR PLAID PRODUCTION APPROVAL
# Expected: 1-2 business days
# ============================================================

# SANDBOX (For local development only)
PLAID_CLIENT_ID_SANDBOX="9aab6b12e387d000ceeddfd"
PLAID_SECRET_SANDBOX="[sandbox-secret-from-plaid-email]"
PLAID_ENV_SANDBOX="sandbox"

# PRODUCTION (Will be set in Vercel, not here!)
# When Plaid sends approval email, you will receive:
# - PLAID_CLIENT_ID (production)
# - PLAID_SECRET (production)
# 
# ⚠️  DO NOT PASTE PRODUCTION KEYS IN THIS FILE! ⚠️
# Instead, add them to Vercel Dashboard:
# 1. Go to https://vercel.com/dashboard
# 2. Select moneylith-v2 → Settings → Environment Variables
# 3. Add each variable with "Production" environment selected:
#    - PLAID_CLIENT_ID = <your production client id>
#    - PLAID_SECRET = <your production secret>
#    - PLAID_ENV = production-eu
#    - PLAID_REDIRECT_URI = https://moneylith-v2.vercel.app

# Local Development Configuration
# For local dev server (npm run dev:vercel)
PLAID_CLIENT_ID=${PLAID_CLIENT_ID_SANDBOX}
PLAID_SECRET=${PLAID_SECRET_SANDBOX}
PLAID_ENV=${PLAID_ENV_SANDBOX}
PLAID_REDIRECT_URI="http://localhost:3000"

# OpenAI (unchanged)
OPENAI_API_KEY="sk-proj-[your-openai-key]"

# TrueLayer (deprecated, can be removed)
TRUELAYER_CLIENT_ID="sandbox-moneylith-c9c408"
TRUELAYER_CLIENT_SECRET="7cb101dc-a409-4632-b16a-9f91dbc95588"
TRUELAYER_ENV="sandbox"
TRUELAYER_REDIRECT_URI="http://localhost:3000/api/truelayer/callback"

# ============================================================
# IMPORTANT SECURITY NOTES:
# ============================================================
# ✅ DO: Keep production keys ONLY in Vercel
# ✅ DO: Rotate keys every 6 months
# ✅ DO: Use .gitignore to prevent accidental commits
# ❌ DON'T: Put production keys in .env file
# ❌ DON'T: Commit .env to GitHub
# ❌ DON'T: Share PLAID_SECRET with anyone
# ============================================================
